# =============================================================================
# OLLAMA GLM PROVIDER CONFIGURATION
# =============================================================================
# Set ACTIVE_PROVIDER=ollama in .env to use this config.

PROVIDER=ollama

# =============================================================================
# DEFAULT / COMMON SETTINGS
# =============================================================================
# Do NOT set LANGGRAPH_API_KEY here — this file may be committed to git.
# Set it in the root .env file (which is gitignored):
#
#   LANGGRAPH_API_KEY=ollama   (Ollama ignores the key value; any string works)
#
# The config loader reads .env first, so the key will be picked up automatically.

LANGGRAPH_MODEL_NAME=glm-4.7-flash
LANGGRAPH_API_URL=http://localhost:11434/v1


# =============================================================================
# RELEVANCE GATE NODE
# Fast binary YES/NO filter — small, cheap, low max_tokens
# =============================================================================

RELEVANCE_GATE_MODEL_NAME=glm-4.7-flash
RELEVANCE_GATE_TEMPERATURE=0.1
RELEVANCE_GATE_MAX_TOKENS=100
RELEVANCE_GATE_TOP_P=0.15
RELEVANCE_GATE_REPEAT_PENALTY=1.2
RELEVANCE_GATE_PRESENCE_PENALTY=0.6
RELEVANCE_GATE_TIMEOUT=60


# =============================================================================
# LOCAL EXTRACTOR NODE
# Structured JSON extraction from a single chunk
# =============================================================================

LOCAL_EXTRACTOR_MODEL_NAME=glm-4.7-flash
LOCAL_EXTRACTOR_TEMPERATURE=0.2
LOCAL_EXTRACTOR_MAX_TOKENS=2000
LOCAL_EXTRACTOR_TOP_P=0.15
LOCAL_EXTRACTOR_REPEAT_PENALTY=1.2
LOCAL_EXTRACTOR_PRESENCE_PENALTY=0.6
LOCAL_EXTRACTOR_TIMEOUT=120


# =============================================================================
# CONTEXT RESOLVER NODE
# Cross-chunk reasoning — highest capability needed
# =============================================================================

CONTEXT_RESOLVER_MODEL_NAME=glm-4.7-flash
CONTEXT_RESOLVER_TEMPERATURE=0.3
CONTEXT_RESOLVER_MAX_TOKENS=2000
CONTEXT_RESOLVER_TOP_P=0.2
CONTEXT_RESOLVER_REPEAT_PENALTY=1.2
CONTEXT_RESOLVER_PRESENCE_PENALTY=0.6
CONTEXT_RESOLVER_TIMEOUT=180
CONTEXT_RESOLVER_MAX_SEGMENTS_FOR_LLM=8
CONTEXT_RESOLVER_MAX_PREVIOUS_ACTIONS=5
